rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function userRole() {
      return isAuth() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isSeller() {
      return userRole() == 'seller';
    }

    // Users
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);   // new user creates their own doc
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Seller profiles
    match /sellerProfiles/{profileId} {
      allow read:   if true;
      allow create: if isSeller() && isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Advertisements
    match /advertisements/{adId} {
      allow read:   if (resource.data.status == 'active' && resource.data.isApproved == true) || isAdmin() || (isSeller() && isOwner(resource.data.sellerId));
      allow create: if isSeller() && isOwner(request.resource.data.sellerId);
      allow update: if (isSeller() && isOwner(resource.data.sellerId)) || isAdmin();
      allow delete: if (isSeller() && isOwner(resource.data.sellerId)) || isAdmin();
    }

    // Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read:   if (isSeller() && isOwner(resource.data.sellerId)) || isAdmin();
      allow create: if isSeller() && isOwner(request.resource.data.sellerId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read:   if isAuth() && (isOwner(resource.data.customerId) || isOwner(resource.data.sellerId) || isAdmin());
      allow create: if isAuth();
      allow update: if (isSeller() && isOwner(resource.data.sellerId)) || isAdmin();
      allow delete: if isAdmin();
    }

    // VIP codes
    match /vipCodes/{codeId} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
